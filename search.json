---
layout: null
---
[
  {% assign search_items = site.posts | sort: "title" %}
  {% for post in search_items %}
    {
      "title": {{ post.title | jsonify }},
      "url": {{ post.url | prepend: site.baseurl | jsonify }},
      "summary": {{ post.summary | default: "" | jsonify }},
      "category": {{ post.categories | join: " " | jsonify }}
    }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
